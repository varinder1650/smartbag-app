# ============================================
# SmartBag Mobile App — Environment Variables
# ============================================
# All variables must be prefixed with EXPO_PUBLIC_ to be accessible in the app.
#
# For local development: copy to .env and fill in values
# For production builds: set values in EAS build profile (eas.json)

# API URLs
EXPO_PUBLIC_API_URL=http://195.35.6.222/api
EXPO_PUBLIC_API_URL_DEV=http://192.168.x.x:8000/api

# Google Sign-In
EXPO_PUBLIC_GOOGLE_ANDROID_CLIENT_ID=
EXPO_PUBLIC_GOOGLE_WEB_CLIENT_ID=

# Cloudinary (file uploads)
EXPO_PUBLIC_CLOUDINARY_CLOUD_NAME=
EXPO_PUBLIC_CLOUDINARY_UPLOAD_PRESET=

# Sentry (error tracking — production only)
EXPO_PUBLIC_SENTRY_DSN=
